# Vector Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_IDS=your_guild_id_here
OWNER_IDS=your_discord_user_id_here
BOT_PREFIX=!

# Timezone (IANA format, e.g. America/Chicago, America/New_York, UTC)
TIMEZONE=America/Chicago

# Unraid SSH (for server monitoring)
UNRAID_HOST=192.168.86.x
UNRAID_USER=root
UNRAID_PASS=your_password

# Home Assistant (smart home control)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token

# TCG Suite (shipping alerts)
TCG_SUITE_URL=http://localhost:5000
SHIP_NOTIFY_CHANNEL=your_channel_id_here
SHIP_NOTIFY_HOUR=7

# GitHub Auto-Update
GITHUB_REPO=yourusername/vector-bot
GITHUB_SECRET=your_webhook_secret
WEBHOOK_PORT=9001
WEBHOOK_HOST=127.0.0.1
POLL_INTERVAL_MINS=5

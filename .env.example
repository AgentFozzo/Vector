# Vector Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_IDS=your_guild_id_here
OWNER_IDS=your_discord_user_id_here
BOT_PREFIX=!

# Unraid SSH (for server monitoring)
UNRAID_HOST=192.168.86.x
UNRAID_USER=root
UNRAID_PASS=your_password

# GitHub Auto-Update
GITHUB_REPO=yourusername/vector-bot
GITHUB_SECRET=your_webhook_secret
WEBHOOK_PORT=9001
POLL_INTERVAL_MINS=5
